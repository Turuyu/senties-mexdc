---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Senties Chauvet · Fianzas para Data Centers | MEXDC',
  description = 'Agente afianzador especializado en programas corporativos de fianzas para el ecosistema de data centers en México. Miembro activo de MEXDC. Más de 30 años de experiencia.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://turuyu.github.io/new-lazaro/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://turuyu.github.io/new-lazaro/" />
    <meta property="og:title" content="Senties Chauvet · Fianzas para Data Centers | MEXDC" />
    <meta
      property="og:description"
      content="Agente afianzador especializado en programas corporativos de fianzas para el ecosistema de data centers en México. Miembro MEXDC."
    />
    <meta property="og:locale" content="es_MX" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- Theme bootstrap: runs BEFORE first paint to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'dark') document.body.classList.add('dark-theme');
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
