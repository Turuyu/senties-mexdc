---
import { getCollection } from 'astro:content';

const partners = (await getCollection('partners')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section class="partners">
  <div class="partners-inner">
    <span class="section-label">Respaldo</span>
    <h2>Socios afianzadores</h2>
    <p>Trabajamos con las principales compañías para diversificar capacidad y tiempos de respuesta.</p>
    <div class="partners-list">
      {partners.map((partner) => (
        <span class="partner">{partner.data.name}</span>
      ))}
    </div>
  </div>
</section>
