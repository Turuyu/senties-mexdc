---
import { getCollection } from 'astro:content';

const bonds = (await getCollection('bonds')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="niveles" class="levels">
  <div class="levels-inner">
    <div class="section-header">
      <span class="section-label">Compromiso</span>
      <h2>Niveles de servicio</h2>
      <p class="section-desc">Tiempos de respuesta claros y medibles. Sin letra chica.</p>
    </div>
    <div class="levels-grid">
      {bonds.map((bond) => (
        <div class="level-item">
          <span class="level-number">{bond.data.metric}</span>
          <h3>{bond.data.title}</h3>
          <p>{bond.data.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
